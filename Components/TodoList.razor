@page "/todo"
@rendermode InteractiveServer
<div class="todo-viewport">
    <div class="glow-layer"></div>
    
    <div class="aesthetic-card">
        <div class="card-header">
            <h2>Task Hub</h2>
            <p>Manage your dynamic workspace entries</p>
        </div>

        <div class="input-container">
            <input type="text"
                   @bind="newTask"
                   @bind:event="oninput"
                   @onkeydown="SubmitOnEnter"
                   placeholder="Track a new milestone..."
                   class="gradient-input" />
            <button class="btn-gradient-add" @onclick="AddTask" disabled="@string.IsNullOrWhiteSpace(newTask)">
                Add
            </button>
        </div>

        <hr class="neon-divider" />

        <div class="task-display-area">
            @if (tasks.Count == 0)
            {
                <div class="empty-state-view">
                    <p class="fade-text">Your stream is completely clear.</p>
                </div>
            }
            else
            {
                <div class="meta-stream-info">
                    <span class="meta-label">Pending Streams</span>
                    <span class="neon-badge">@tasks.Count Nodes</span>
                </div>
                
                <ul class="premium-list">
                    @foreach (var task in tasks)
                    {
                        <li class="premium-item">
                            <span class="bullet-accent"></span>
                            <span class="item-display-text">@task</span>
                        </li>
                    }
                </ul>
            }
        </div>

        @if (tasks.Count > 0)
        {
            <button class="btn-neon-outline" @onclick="ClearAllTasks">
                Flush Workspace Data
            </button>
        }
    </div>
</div>

@code {
    private string newTask = string.Empty;
    private List<string> tasks = new();

    private void AddTask()
    {
        if (!string.IsNullOrWhiteSpace(newTask))
        {
            tasks.Add(newTask.Trim());
            newTask = string.Empty;
        }
    }

    private void SubmitOnEnter(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            AddTask();
        }
    }

    private void ClearAllTasks()
    {
        tasks.Clear();
    }
}