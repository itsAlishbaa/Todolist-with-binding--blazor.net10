@page "/todo"

<div class="app-viewport">
    <div class="todo-glass-card">
        <div class="brand-header">
            <h2>Workspace</h2>
            <span class="pulse-dot"></span>
        </div>

        <div class="input-hub">
            <input type="text"
                   @bind="newTask"
                   @bind:event="oninput"
                   @onkeydown="SubmitOnEnter"
                   placeholder="Review architectural patterns..."
                   class="premium-input" />
            <button class="action-trigger add-node" @onclick="AddTask" disabled="@string.IsNullOrWhiteSpace(newTask)">
                <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M8 1v14M1 8h14" /></svg>
            </button>
        </div>

        <div class="workspace-body">
            @if (tasks.Count == 0)
            {
                <div class="void-state">
                    <div class="void-icon">//</div>
                    <p>Stack is empty. Secure a clean workflow.</p>
                </div>
            }
            else
            {
                <div class="metrics-bar">
                    <span>Active Nodes</span>
                    <span class="counter-badge">@tasks.Count</span>
                </div>
                
                <ul class="node-stream">
                    @foreach (var task in tasks)
                    {
                        <li class="stream-item">
                            <span class="item-text">@task</span>
                        </li>
                    }
                </ul>
            }
        </div>

        @if (tasks.Count > 0)
        {
            <div class="card-footer">
                <button class="action-trigger flush-stream" @onclick="ClearAllTasks">
                    Flush Dynamic List
                </button>
            </div>
        }
    </div>
</div>

@code {
    private string newTask = string.Empty;
    private List<string> tasks = new();

    private void AddTask()
    {
        if (!string.IsNullOrWhiteSpace(newTask))
        {
            tasks.Add(newTask.Trim());
            newTask = string.Empty;
        }
    }

    private void SubmitOnEnter(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            AddTask();
        }
    }

    private void ClearAllTasks()
    {
        tasks.Clear();
    }
}