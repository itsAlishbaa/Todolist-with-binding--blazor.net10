@page "/todo"
@rendermode InteractiveServer

<div class="dashboard-viewport">
    <div class="premium-dark-card">
        <div class="card-header">
            <h2>Simple To-Do List</h2>
            <p>Add and manage your tasks instantly</p>
        </div>

        <div class="input-row">
            <input type="text"
                   @bind="newTask"
                   @bind:event="oninput"
                   @onkeydown="HandleKeyDown"
                   placeholder="Add a new task..."
                   class="dark-input" />
            <button class="add-action-btn" @onclick="AddTask" disabled="@string.IsNullOrWhiteSpace(newTask)">
                Add
            </button>
        </div>

        <div class="list-display-container">
            @if (tasks.Count == 0)
            {
                <div class="empty-list-box">
                    <p>Your list is completely clear.</p>
                </div>
            }
            else
            {
                <div class="list-header-meta">
                    <span>Total Tasks</span>
                    <span class="count-pill">@tasks.Count Items</span>
                </div>
                
                <ul class="task-items-container">
                    @foreach (var task in tasks)
                    {
                        <li class="single-task-row">
                            <span class="bullet-glow"></span>
                            <span class="task-string-value">@task</span>
                        </li>
                    }
                </ul>
            }
        </div>

        @if (tasks.Count > 0)
        {
            <button class="action-btn-main btn-glow-red" @onclick="ClearList">
                Clear All Tasks
            </button>
        }
    </div>
</div>

@code {
    private string newTask = string.Empty;
    private List<string> tasks = new();

    private void AddTask()
    {
        if (!string.IsNullOrWhiteSpace(newTask))
        {
            tasks.Add(newTask.Trim());
            newTask = string.Empty;
        }
    }

    private void HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            AddTask();
        }
    }

    private void ClearList()
    {
        tasks.Clear();
    }
}